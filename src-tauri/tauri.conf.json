{
  "productName": "DM Voice",
  "version": "0.4.8",
  "identifier": "de.dmvoice.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "overlay",
        "url": "overlay/index.html",
        "width": 220,
        "height": 52,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "focusable": false,
        "shadow": false,
        "resizable": false,
        "x": 0,
        "y": 0,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/ggml-metal.metal", "Assets.car"],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "13.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/m0nji/DM_Voice/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2OEZERTVDMkMyMzg2NjkKUldScGhpTXNYTjZQTmhHNnAwK1NSNXcwVmE1MHhVL0tkZnZhMWFTUFVVQTk0N3k3M3JCQVRYeUQK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
